<div class="wrap">
<header class="header">
  <div class="header-inner">
    <div class="header-left">
      <a href="index.html" title="Back to Toolkit" style="display:flex"><img src="data:image/png;base64," alt="ARENCON Inc." class="header-logo"></a>
      <span class="header-tool-name">Trapeze Hanger Calculator</span>
    </div>
