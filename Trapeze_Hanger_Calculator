<style>
:root{
  --ac:#9C2742;--ac2:#7d1f35;--ac3:#c13a58;
  --bg:#f5f4f1;--card:#fff;--border:#e2e0db;
  --txt:#1a1a1a;--txt2:#6b6560;--txt3:#9e9890;
  --green:#2d6b22;--greenBg:#e8f5e0;--greenBdr:#4a8c3f;
  --red:#c0392b;--red-bg:#fdecea;
  --amber:#b8860b;--amber-bg:#fef3e0;
  --blue:#1a5fb4;--blue-bg:#e8f0fe;
  --shadow:0 1px 3px rgba(0,0,0,.04),0 4px 16px rgba(0,0,0,.06);
  --radius:8px;
}
/* === STANDARD HEADER (Style Guide) === */
.header{background:var(--ac);color:#fff;padding:0 24px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(156,39,66,.3);}
.header-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:56px;}
.header-left{display:flex;align-items:center;gap:14px;}
.header-logo{height:32px;width:auto;background:#fff;padding:3px 6px;border-radius:5px;}
.header-tool-name{font-family:'Outfit',system-ui,sans-serif;font-size:16px;font-weight:600;letter-spacing:.5px;opacity:.9;}
.header-right{display:flex;align-items:center;gap:8px;}
.hdr-btn{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);color:#fff;padding:6px 14px;border-radius:6px;font-family:'Outfit',system-ui,sans-serif;font-size:12px;font-weight:600;letter-spacing:.5px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:6px;}
.hdr-btn:hover{background:rgba(255,255,255,.25);}
.hdr-btn svg{width:14px;height:14px;}
/* === STANDARD FOOTER === */
.footer{background:#2a2522;color:rgba(255,255,255,.5);padding:24px;text-align:center;font-size:11px;line-height:1.6;font-family:'Outfit',system-ui,sans-serif;}
.footer strong{color:rgba(255,255,255,.75);}
/* === TOAST === */
.toast-wrap{position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:999;}
.toast{background:#2a2522;color:#fff;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,.3);opacity:0;transform:translateY(10px);transition:all .3s;font-family:'Outfit',system-ui,sans-serif;}
.toast.show{opacity:1;transform:translateY(0);}
/* === PRINT === */
@media print{.header,.footer,.no-print{display:none!important;}body{background:#fff;}.wrap{box-shadow:none;}}

*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Calibri,'DM Sans',system-ui,sans-serif;background:var(--bg);color:var(--txt);padding:16px}
.wrap{max-width:740px;margin:0 auto;background:var(--card);border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.06),0 8px 24px rgba(0,0,0,.06);overflow:hidden}
/* Header: now using standard .header classes from Style Guide */
/* Section headers */
.sec{background:#f0efec;padding:6px 20px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--ac);border-bottom:1px solid var(--border)}
/* Input grid */
.grid{display:grid;grid-template-columns:42px 1fr 1fr auto;padding:0 16px;gap:0}
.grow{padding:8px 6px;border-bottom:1px solid #f0efec;display:flex;align-items:center;font-size:13px}
.grow.sym{font-weight:700;font-style:italic;justify-content:center;color:var(--ac)}
.grow.desc{color:var(--txt);font-size:14px}
.grow.mid{color:var(--txt2);font-size:12px;justify-content:center;text-align:center}
.grow.val{justify-content:center}
.grow.unit{font-size:11px;color:var(--txt2);padding-left:4px;min-width:28px}
.grow.span2{grid-column:span 2}
.grow.span3{grid-column:span 3}
.grow.full{grid-column:1/-1}
.inp{width:72px;text-align:center;font-weight:700;font-size:14px;font-family:Calibri,sans-serif;border:2px solid var(--greenBdr);background:var(--greenBg);border-radius:4px;padding:3px 4px}
.inp:focus{outline:none;border-color:var(--green);box-shadow:0 0 0 3px rgba(45,107,34,.15)}
select.inp{width:auto;min-width:100px;appearance:auto;cursor:pointer;font-family:Calibri,system-ui,sans-serif}
.out{font-family:Calibri,sans-serif;font-weight:700;font-size:17px;color:var(--txt)}
.out-sm{font-size:13px;color:var(--txt2);font-style:italic}
.hl-row{background:var(--greenBg)!important}
.hl-row .out{color:var(--green);border:2px solid var(--greenBdr);border-radius:4px;padding:2px 8px}
/* Result cards */
.res-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;padding:12px 16px}
.res-card{background:#fafaf8;border:1px solid var(--border);border-radius:6px;padding:10px 8px;text-align:center}
.res-card.active{background:var(--greenBg);border-color:var(--greenBdr)}
.res-label{font-size:12px;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;font-weight:600}
.res-val{font-family:Calibri,sans-serif;font-weight:700;font-size:18px;color:var(--txt);line-height:1.3}
.res-card.active .res-val{color:var(--green)}
/* Detail */
.det-hdr{background:#f0efec;padding:6px 20px;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(--ac);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.det-area{padding:8px;background:#fff}
/* Footer */
.ftr{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-top:1px solid var(--border);background:#fafaf8}
.ftr-txt{font-size:9px;color:var(--txt2);max-width:480px;line-height:1.4}
.qr{width:64px;height:64px;border:1px solid var(--border);border-radius:4px;overflow:hidden;flex-shrink:0}
</style>
</head>
