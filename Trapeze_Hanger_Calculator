const cpm={'Sch. 40 Pipe':'c40','Sch. 10 Pipe':'c10','Angle Iron':'cA','Unistrut':'cSt'};
function go(){
  const d=+document.getElementById('pd').value,sch=document.getElementById('ps').value;
  const af=+(document.getElementById('af').value||0),ai=+(document.getElementById('ai').value||0);
  const bf=+(document.getElementById('bf').value||0),bi=+(document.getElementById('bi').value||0);
  const pref=document.getElementById('tp').value,ed=document.getElementById('ne').value;
  const a=af+ai/12,b=bf+bi/12,span=a+b;
  const Le=Math.abs(a-b)<.01?span:4*a*b/(a+b);
  const sr=calcSreq(d,sch,Le);
  const r=rodNFPA(d);
  const sF=Math.floor(span),sI=Math.round((span-sF)*12);
  document.getElementById('oS').textContent=sF+"'-"+sI+'"';
  document.getElementById('oL').textContent=(Math.round(Le*10)/10).toFixed(1);
  document.getElementById('oR').textContent=sr.toFixed(2);
  document.getElementById('oA').textContent=fm(ANG,sr);
  document.getElementById('o10').textContent=fm(TS10,sr);
  document.getElementById('o40').textContent=fm(TS40,sr);
  document.getElementById('oSt').textContent=fm(STR,sr);
  document.getElementById('oRd').textContent=r+'"';
  // Highlight active card
  ['cA','c10','c40','cSt'].forEach(id=>{document.getElementById(id).classList.remove('active')});
  const hId=cpm[pref];if(hId)document.getElementById(hId).classList.add('active');
  let tL;if(pref==='Angle Iron')tL=fm(ANG,sr);else if(pref==='Sch. 10 Pipe')tL=fm(TS10,sr).replace('"','')+' Sch. 10';else if(pref==='Unistrut')tL=fm(STR,sr);else tL=fm(TS40,sr).replace('"','')+' Sch. 40';
  draw(af,ai,bf,bi,d,sch,tL,r,pref);
}
// === DRAWING ENGINE ===
function draw(af,ai,bf,bi,d,sch,trapL,rd,pref){
  const aIn=af*12+ai,bIn=bf*12+bi,spIn=aIn+bIn;
  if(spIn<=0){document.getElementById('det').innerHTML='';return;}
  const ODs={1:1.315,1.25:1.66,1.5:1.9,2:2.375,2.5:2.875,3:3.5,3.5:4,4:4.5,5:5.563,6:6.625,8:8.625,10:10.75};
  const mainOD=ODs[d]||3.5;
  const W=700,mg=60;
  const p=Math.min((W-2*mg)/spIn,7);
  const sL=mg,sR=mg+spIn*p,pX=mg+aIn*p;
  const pR=Math.max(6,mainOD/2*p);
  const isPipe=pref==='Sch. 40 Pipe'||pref==='Sch. 10 Pipe';
  const isAngle=pref==='Angle Iron';
  const isStrut=pref==='Unistrut';
  let tH;
  if(isPipe){const uf={'¼':.25,'½':.5,'¾':.75};let sz=3;const pm=trapL.match(/(\d+)/);if(pm){sz=+pm[1];for(const[ch,v]of Object.entries(uf))if(trapL.includes(ch)){sz+=v;break;}}tH=Math.max(3,sz*p);}
  else if(isAngle){tH=Math.max(3,2.5*p);}
  else{tH=Math.max(3,4.875*p);}

  // Beam shifted further apart: add extra margin outside each structure point
  const beamW=8*p,beamH=8*p,fT=Math.max(2,beamH*.12),wT=Math.max(2,beamW*.06);
  const bLcx=sL-beamW/2,bRcx=sR+beamW/2; // beam right-edge at sL, left-edge at sR

  const nutW=Math.max(2.5,.6*p),nutD=Math.max(1.5,.286*p);
  const washW=Math.max(3.5,1*p),washD=Math.max(1,.143*p);
  const rodSW=Math.max(1.2,.5*p*.35);
  const aC='#9C2742',aCs='#7d1f35';

  const Y0=4;
  const clampTopY=Y0;
  const beamTFtop=Y0+0.778*p;
  const beamTFbot=beamTFtop+fT;
  const clampBotY=Y0+2.03*p;
  const beamBFtop=beamTFtop+beamH-fT;
  const beamBFbot=beamTFtop+beamH;
  const rodVisStart=clampBotY; // rod from clamp bottom, through/alongside beam, to trapeze
  const tTop=Y0+15*p;
  const tBot=tTop+tH;
  const hRodTopY=tBot+washD+nutD;
  const hRodBotY=Y0+22*p; // extended for clearance
  const pY=Y0+28.5*p; // moved down for clearance from trapeze
  const hBotY=pY+pR+Math.max(2,.5*p);
  const tL_=sL-Math.max(4,6*p*.4);
  const tR_=sR+Math.max(4,6*p*.4);
  const svgH=Math.max(250,hBotY+50);

  let s=`<svg xmlns="http://www.w3.org/2000/svg" width="${W}" height="${svgH}" style="font-family:Calibri,'DM Sans',Arial,sans-serif"><rect width="${W}" height="${svgH}" fill="#fff"/>`;

  // === I-BEAMS (shifted outward) ===
  function beam(cx){
    const hw=beamW/2;
    s+=`<rect x="${cx-hw}" y="${beamTFtop}" width="${beamW}" height="${fT}" fill="#3d3d3d" stroke="#222" stroke-width=".6"/>`;
    s+=`<rect x="${cx-wT/2}" y="${beamTFbot}" width="${wT}" height="${beamBFtop-beamTFbot}" fill="#3d3d3d" stroke="#222" stroke-width=".6"/>`;
    s+=`<rect x="${cx-hw}" y="${beamBFtop}" width="${beamW}" height="${fT}" fill="#3d3d3d" stroke="#222" stroke-width=".6"/>`;
  }
  beam(bLcx);beam(bRcx);

  // === BEAM CLAMPS (exact MeyerFire polygon, at structure points sL/sR) ===
  function clamp(cx,bcx,dir){
    // cx=structure point (where rod is), bcx=beam center, dir=1 left/-1 right
    const d29=2/9*p;
    const xR=1*p,xL=-1.09*p;
    const yTop=clampTopY,yChan=Y0+0.75*p,yDrop=Y0+1.5*p,yBot=clampBotY;
    if(dir===1){
      s+=`<path d="M${cx+xR} ${yTop} L${cx} ${yTop} L${cx+xL} ${yChan} L${cx} ${yChan} L${cx} ${yDrop} L${cx+xL} ${yDrop} L${cx+xL} ${yBot} L${cx+xR} ${yBot} Z" fill="none" stroke="#555" stroke-width="1.1"/>`;
    }else{
      s+=`<path d="M${cx-xR} ${yTop} L${cx} ${yTop} L${cx-xL} ${yChan} L${cx} ${yChan} L${cx} ${yDrop} L${cx-xL} ${yDrop} L${cx-xL} ${yBot} L${cx-xR} ${yBot} Z" fill="none" stroke="#555" stroke-width="1.1"/>`;
    }
  }
  clamp(sL,bLcx,1);clamp(sR,bRcx,-1);

  // === RODS drawn after trapeze ===

  // === TRAPEZE ===
  if(isPipe){
    const r=Math.min(tH/2,10);
    if(r>1.5)s+=`<path d="M${tL_+r} ${tTop} L${tR_-r} ${tTop} A${r} ${r} 0 0 1 ${tR_-r} ${tBot} L${tL_+r} ${tBot} A${r} ${r} 0 0 1 ${tL_+r} ${tTop}" fill="none" stroke="${aC}" stroke-width="1.6"/>`;
    else s+=`<rect x="${tL_}" y="${tTop}" width="${tR_-tL_}" height="${tH}" fill="none" stroke="${aC}" stroke-width="1.6" rx="1"/>`;
  }else if(isAngle){
    // Angle iron: double line top (two close horizontal lines), single bottom, verticals
    const lt=Math.max(1.5,tH*.12); // leg thickness
    // Bottom leg (single thick line)
    s+=`<line x1="${tL_}" y1="${tBot}" x2="${tR_}" y2="${tBot}" stroke="${aC}" stroke-width="1.4"/>`;
    // Top leg (DOUBLE lines close together)
    s+=`<line x1="${tL_}" y1="${tTop}" x2="${tR_}" y2="${tTop}" stroke="${aC}" stroke-width="1.4"/>`;
    s+=`<line x1="${tL_}" y1="${tTop+lt}" x2="${tR_}" y2="${tTop+lt}" stroke="${aC}" stroke-width="1"/>`;
    // Verticals
    s+=`<line x1="${tL_}" y1="${tTop}" x2="${tL_}" y2="${tBot}" stroke="${aC}" stroke-width="1.4"/>`;
    s+=`<line x1="${tR_}" y1="${tTop}" x2="${tR_}" y2="${tBot}" stroke="${aC}" stroke-width="1.4"/>`;
  }else if(isStrut){
    // Unistrut C-channel
    const midY=tTop+(tBot-tTop)*0.35;
    // Bottom (continuous line)
    s+=`<line x1="${tL_}" y1="${tBot}" x2="${tR_}" y2="${tBot}" stroke="${aC}" stroke-width="1.6"/>`;
    // Left vertical
    s+=`<line x1="${tL_}" y1="${tBot}" x2="${tL_}" y2="${tTop}" stroke="${aC}" stroke-width="1.6"/>`;
    // Right vertical
    s+=`<line x1="${tR_}" y1="${tBot}" x2="${tR_}" y2="${tTop}" stroke="${aC}" stroke-width="1.6"/>`;
    // Middle line (slot opening reference)
    s+=`<line x1="${tL_}" y1="${midY}" x2="${tR_}" y2="${midY}" stroke="${aC}" stroke-width="1"/>`;
    // Top line: full continuous line across entire width (matching bottom)
    s+=`<rect x="${tL_}" y="${tTop-1}" width="${tR_-tL_}" height="2" fill="${aC}"/>`;
  }

  // === RODS (from beam bottom to trapeze) ===
  s+=`<line x1="${sL}" y1="${rodVisStart}" x2="${sL}" y2="${tTop}" stroke="#555" stroke-width="${Math.max(2,rodSW*1.5)}"/>`;
  s+=`<line x1="${sR}" y1="${rodVisStart}" x2="${sR}" y2="${tTop}" stroke="#555" stroke-width="${Math.max(2,rodSW*1.5)}"/>`;

  // === NUTS + WASHERS ===
  // For unistrut: bottom nuts land on middle line, not tBot
  const strutMidY=isStrut?tTop+(tBot-tTop)*0.35:null;
  function nw(x,yB,ab){
    if(ab){s+=`<rect x="${x-washW/2}" y="${yB-washD}" width="${washW}" height="${washD}" fill="#ccc" stroke="#999" stroke-width=".3"/>`;s+=`<rect x="${x-nutW/2}" y="${yB-washD-nutD}" width="${nutW}" height="${nutD}" fill="#aaa" stroke="#888" stroke-width=".4"/>`;}
    else{s+=`<rect x="${x-washW/2}" y="${yB}" width="${washW}" height="${washD}" fill="#ccc" stroke="#999" stroke-width=".3"/>`;s+=`<rect x="${x-nutW/2}" y="${yB+washD}" width="${nutW}" height="${nutD}" fill="#aaa" stroke="#888" stroke-width=".4"/>`;}
  }
  [sL,sR,pX].forEach(x=>{nw(x,tTop,true);});
  // Below trapeze: for strut, land on middle line; otherwise on tBot
  const botNutY=isStrut?strutMidY:tBot;
  [sL,sR,pX].forEach(x=>{nw(x,botNutY,false);});

  // === HANGER ROD (center) ===
  const hRodActualTop=botNutY+washD+nutD;
  s+=`<line x1="${pX}" y1="${hRodActualTop}" x2="${pX}" y2="${hRodBotY}" stroke="#555" stroke-width="${Math.max(rodSW,1.5)}"/>`;

  // === RING HANGER ===
  const hTopRel=(26.8125-19.34)*p;
  const hangerTop=pY-hTopRel;
  // Nut + washer at hanger rod bottom (inside the ring top)
  nw(pX,hRodBotY,false);
  const innerNutBot=hRodBotY+washD+nutD;

  // Band top pieces (connect rod to diagonals)
  const btW=Math.max(1.5,.5*p),btH=Math.max(2,.4*p);
  const bandTopY=innerNutBot;
  s+=`<rect x="${pX-btW-rodSW/2}" y="${bandTopY}" width="${btW}" height="${btH}" fill="none" stroke="#4a2a1a" stroke-width="1"/>`;
  s+=`<rect x="${pX+rodSW/2}" y="${bandTopY}" width="${btW}" height="${btH}" fill="none" stroke="#4a2a1a" stroke-width="1"/>`;

  const hTpHW=btW+rodSW/2;
  const hPipeHW=pR+Math.max(1.5,.35*p);
  const diagTopY=bandTopY+btH; // diagonals start at bottom of band top pieces
  const tAng=1.22;
  const tangLX=pX-hPipeHW*Math.sin(tAng);
  const tangRX=pX+hPipeHW*Math.sin(tAng);
  const tangY_=pY-hPipeHW*Math.cos(tAng);

  // Outer
  s+=`<path d="M${pX-hTpHW} ${diagTopY} L${tangLX} ${tangY_} A${hPipeHW} ${hPipeHW} 0 1 0 ${tangRX} ${tangY_} L${pX+hTpHW} ${diagTopY}" fill="none" stroke="#4a2a1a" stroke-width="1.8"/>`;
  // Inner
  const bt=Math.max(1,.25*p),iR=hPipeHW-bt,iTpHW=Math.max(.5,hTpHW-bt*.3);
  s+=`<path d="M${pX-iTpHW} ${diagTopY+bt} L${pX-iR*Math.sin(tAng)} ${pY-iR*Math.cos(tAng)} A${iR} ${iR} 0 1 0 ${pX+iR*Math.sin(tAng)} ${pY-iR*Math.cos(tAng)} L${pX+iTpHW} ${diagTopY+bt}" fill="none" stroke="#4a2a1a" stroke-width=".5"/>`;
  s+=`<line x1="${pX-hTpHW}" y1="${diagTopY}" x2="${pX-iTpHW}" y2="${diagTopY+bt}" stroke="#4a2a1a" stroke-width=".5"/>`;
  s+=`<line x1="${pX+hTpHW}" y1="${diagTopY}" x2="${pX+iTpHW}" y2="${diagTopY+bt}" stroke="#4a2a1a" stroke-width=".5"/>`;

  // === PIPE ===
  s+=`<circle cx="${pX}" cy="${pY}" r="${pR}" fill="none" stroke="#4a1a0a" stroke-width="2"/>`;

  // === WAVY LINE ===
  if(pR>4){
    const wA=pR*.08,wW=pR*.7,pts=24;
    let w1=`M${pX-wW} ${pY}`;let w2=`M${pX-wW*.85} ${pY+wA*.6}`;
    for(let i=1;i<=pts;i++){const t=i/pts;w1+=` L${(pX-wW+2*wW*t).toFixed(1)} ${(pY+Math.sin(t*Math.PI*2)*wA).toFixed(1)}`;w2+=` L${(pX-wW*.85+1.7*wW*t).toFixed(1)} ${(pY+wA*.6+Math.sin(t*Math.PI*2+.5)*wA*.6).toFixed(1)}`;}
    s+=`<path d="${w1}" fill="none" stroke="#2255AA" stroke-width=".9" opacity=".65"/>`;
    s+=`<path d="${w2}" fill="none" stroke="#2255AA" stroke-width=".6" opacity=".45"/>`;
  }

  // === LABELS ===
  const ss=sch==='10'?'Sch. 10':'Sch. 40';
  // Helper: format pipe diameter with Unicode fractions
  function fmtD(v){const f={0.25:'¼',0.5:'½',0.75:'¾'};const w=Math.floor(v),frac=Math.round((v-w)*100)/100;return f[frac]!==undefined?(w>0?w:'')+f[frac]:String(v);}
  // Rod labels — positioned to right of each beam, same size as trapeze label
  s+=`<text x="${bLcx+beamW/2+3}" y="${beamTFtop+beamH/2}" text-anchor="start" font-size="10" font-weight="bold" fill="#555">${rd}" rod</text>`;
  s+=`<text x="${bRcx+beamW/2+3}" y="${beamTFtop+beamH/2}" text-anchor="start" font-size="10" font-weight="bold" fill="#555">${rd}" rod</text>`;
  // Trapeze label
  s+=`<text x="${(tL_+tR_)/2}" y="${tTop-washD-nutD-3}" text-anchor="middle" font-size="10" font-weight="bold" fill="${aC}">${trapL}</text>`;
  // Pipe labels
  s+=`<text x="${pX+hPipeHW+8}" y="${pY-3}" text-anchor="start" font-size="10" font-weight="bold" fill="#555">${rd}" rod</text>`;
  s+=`<text x="${pX+hPipeHW+8}" y="${pY+9}" text-anchor="start" font-size="10" font-weight="bold" fill="${aC}">${fmtD(d)}" ${ss}</text>`;

  // === DIMENSIONS (above trapeze) ===
  const dY=tTop-22,dC='#8a7040';
  s+=`<line x1="${sL}" y1="${dY}" x2="${pX}" y2="${dY}" stroke="${dC}" stroke-width=".8"/>`;
  s+=`<line x1="${pX}" y1="${dY}" x2="${sR}" y2="${dY}" stroke="${dC}" stroke-width=".8"/>`;
  [sL,pX,sR].forEach(x=>{s+=`<line x1="${x}" y1="${dY-3}" x2="${x}" y2="${dY+3}" stroke="${dC}" stroke-width=".8"/>`;});
  s+=`<text x="${(sL+pX)/2}" y="${dY-4}" text-anchor="middle" font-size="10" font-weight="bold" fill="${dC}">${af}'-${ai}"</text>`;
  s+=`<text x="${(pX+sR)/2}" y="${dY-4}" text-anchor="middle" font-size="10" font-weight="bold" fill="${dC}">${bf}'-${bi}"</text>`;
  const sbY=hBotY+10,ft=12*p;
  if(ft>8){s+=`<line x1="${sL}" y1="${sbY}" x2="${sL+ft*2}" y2="${sbY}" stroke="#777" stroke-width=".5"/>`;[0,1,2].forEach(i=>{const sx=sL+ft*i;s+=`<line x1="${sx}" y1="${sbY-2}" x2="${sx}" y2="${sbY+2}" stroke="#777" stroke-width=".5"/>`;s+=`<text x="${sx}" y="${sbY+9}" text-anchor="middle" font-size="7" fill="#777">${i} ft</text>`;});}
  s+='</svg>';
  document.getElementById('det').innerHTML=s;
}

// ═══════════════════════════════════════════════════════
// ARENCON STANDARD SAVE/LOAD/PDF (Style Guide)
// ═══════════════════════════════════════════════════════
const TOOL_ID = 'trapeze_hanger_calculator';
const TOOL_DISPLAY = 'Trapeze Hanger Calculator';

function toast(msg) {
  const el = document.getElementById('toast');
  if (!el) return;
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(el._t);
  el._t = setTimeout(() => el.classList.remove('show'), 2500);
}

function gatherFormData() {
  return {
    pd: document.getElementById('pd').value,
    ps: document.getElementById('ps').value,
    af: document.getElementById('af').value,
    ai: document.getElementById('ai').value,
    bf: document.getElementById('bf').value,
    bi: document.getElementById('bi').value,
    tp: document.getElementById('tp').value,
    ne: document.getElementById('ne').value
  };
}

function populateFormData(data) {
  if (data.pd) document.getElementById('pd').value = data.pd;
  if (data.ps) document.getElementById('ps').value = data.ps;
  if (data.af) document.getElementById('af').value = data.af;
  if (data.ai) document.getElementById('ai').value = data.ai;
  if (data.bf) document.getElementById('bf').value = data.bf;
  if (data.bi) document.getElementById('bi').value = data.bi;
  if (data.tp) document.getElementById('tp').value = data.tp;
  if (data.ne) document.getElementById('ne').value = data.ne;
  go(); // recalculate
}

function autoSave() {
  const data = gatherFormData();
  data._toolId = TOOL_ID;
  data._savedAt = new Date().toISOString();
  localStorage.setItem('arencon_' + TOOL_ID, JSON.stringify(data));
}

function autoRestore() {
  try {
    const raw = localStorage.getItem('arencon_' + TOOL_ID);
    if (raw) {
      const data = JSON.parse(raw);
      populateFormData(data);
      toast('Restored previous session');
    }
  } catch(e) { /* ignore */ }
}

function saveReport() {
  const data = gatherFormData();
  data._toolId = TOOL_ID;
  data._toolName = TOOL_DISPLAY;
  data._savedAt = new Date().toISOString();
  data._version = '1.0';
  const blob = new Blob([JSON.stringify(data, null, 2)], {type: 'application/json'});
  if (navigator.share && navigator.canShare && navigator.canShare({files: [new File([blob], 'report.json')]})) {
    const file = new File([blob], generateFileName() + '.json', {type: 'application/json'});
    navigator.share({ files: [file], title: TOOL_DISPLAY + ' Report' })
      .then(() => toast('Report shared'))
      .catch(() => downloadBlob(blob));
  } else {
    downloadBlob(blob);
  }
}

function downloadBlob(blob) {
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = generateFileName() + '.json';
  a.click();
  URL.revokeObjectURL(url);
  toast('Report saved');
}

function generateFileName() {
  const date = new Date().toISOString().slice(0,10);
  return TOOL_ID + '_' + date;
}

function loadReport() {
  const input = document.getElementById('loadInput');
  input.onchange = function() {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function() {
      try {
        const data = JSON.parse(reader.result);
        if (data._toolId && data._toolId !== TOOL_ID) {
          if (!confirm('This report was made with "' + (data._toolName||data._toolId) + '". Load anyway?')) return;
        }
        populateFormData(data);
        autoSave();
        toast('Report loaded');
      } catch(e) {
        alert('Could not read this file.');
      }
    };
    reader.readAsText(file);
    this.value = '';
  };
  input.click();
}

function exportPDF() {
  window.print();
}

// Auto-save on input changes
document.addEventListener('input', function(e) {
  if (e.target.closest('.wrap')) autoSave();
});
document.addEventListener('change', function(e) {
  if (e.target.closest('.wrap')) autoSave();
});

// Auto-restore on load
document.addEventListener('DOMContentLoaded', autoRestore);

go();
</script>
