<!-- INPUT SECTION -->
<div class="sec">Pipe Being Supported</div>
<div class="grid">
  <div class="grow sym">d</div><div class="grow desc">Pipe Diameter</div><div class="grow val"><select id="pd" class="inp" onchange="go()"><option value="1">1"</option><option value="1.25">1¼"</option><option value="1.5">1½"</option><option value="2">2"</option><option value="2.5">2½"</option><option value="3">3"</option><option value="3.5">3½"</option><option value="4">4"</option><option value="5">5"</option><option value="6" selected>6"</option><option value="8">8"</option><option value="10">10"</option></select></div><div class="grow unit">in</div>
  <div class="grow sym">t</div><div class="grow desc">Pipe Schedule</div><div class="grow val"><select id="ps" class="inp" onchange="go()"><option value="10">Schedule 10</option><option value="40">Schedule 40</option></select></div><div class="grow unit"></div>
  <div class="grow sym">a</div><div class="grow desc">Distance to 1st Support</div><div class="grow val"><input type="number" id="af" class="inp" value="2" min="0" max="20" oninput="go()" style="width:48px"> ft <input type="number" id="ai" class="inp" value="6" min="0" max="11" oninput="go()" style="width:48px"> in</div><div class="grow unit"></div>
  <div class="grow sym">b</div><div class="grow desc">Distance to 2nd Support</div><div class="grow val"><input type="number" id="bf" class="inp" value="3" min="0" max="20" oninput="go()" style="width:48px"> ft <input type="number" id="bi" class="inp" value="6" min="0" max="11" oninput="go()" style="width:48px"> in</div><div class="grow unit"></div>
  <div class="grow sym">—</div><div class="grow desc">Preferred Trapeze Type</div><div class="grow val"><select id="tp" class="inp" onchange="go()"><option>Sch. 40 Pipe</option><option>Sch. 10 Pipe</option><option>Angle Iron</option><option>Unistrut</option></select></div><div class="grow unit"></div>
  <div class="grow sym">—</div><div class="grow desc">NFPA 13 Edition</div><div class="grow val"><select id="ne" class="inp" onchange="go()"><option>2022</option><option>2019</option><option>2016</option><option>2013</option></select></div><div class="grow unit"></div>
</div>
<!-- SOLUTION SECTION -->
<div class="sec">Solution</div>
<div class="grid">
  <div class="grow sym">S</div><div class="grow desc">Span (between structures)</div><div class="grow val"><span class="out" id="oS"></span></div><div class="grow unit"></div>
  <div class="grow sym">L</div><div class="grow desc">Equivalent Length of Span</div><div class="grow val"><span class="out" id="oL"></span></div><div class="grow unit">ft</div>
  <div class="grow sym">S<sub>req</sub></div><div class="grow desc">Section Modulus Required</div><div class="grow val"><span class="out" id="oR" style="font-size:17px;color:var(--ac)"></span></div><div class="grow unit">in³</div>
</div>
<div class="grid" style="padding-top:4px">
  <div class="grow sym">r</div><div class="grow desc">Rod Size Required</div><div class="grow val"><span class="out" id="oRd"></span></div><div class="grow unit"></div>
</div>
<!-- TRAPEZE OPTIONS -->
<div class="sec">Minimum Size Trapeze Required</div>
<div class="res-grid">
  <div class="res-card" id="cA"><div class="res-label">Angle Iron ¹</div><div class="res-val" id="oA"></div></div>
  <div class="res-card" id="c10"><div class="res-label">Sch. 10 Pipe</div><div class="res-val" id="o10"></div></div>
  <div class="res-card" id="c40"><div class="res-label">Sch. 40 Pipe</div><div class="res-val" id="o40"></div></div>
  <div class="res-card" id="cSt"><div class="res-label">Strut ²</div><div class="res-val" id="oSt"></div></div>
</div>
<!-- DETAIL -->
<div class="det-hdr">Detail</div>
<div class="det-area" id="det"></div>

<footer class="footer">
  <strong>ARENCON Inc.</strong> — Fire Protection Engineering<br>
